      "comment": "A score displayed in a match scoreboard.",
      "isCommentAutoGenerated": true
    },
    "%lld / %lld": {
      "comment": "A label showing the number of matches won and the total number of matches played. The first argument is the number of matches won. The second argument is the total number of matches played.",
